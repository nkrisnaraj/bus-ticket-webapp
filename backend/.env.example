MONGO_URI="mongodb+srv://example-user:example-password@cluster.mongodb.net/QBus?appName=Cluster0"
JWT_SECRET="example-jwt-secret-key"

# Backend port
PORT=5000

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:5173

# ── Default Admin Seed (auto-created on first run) ─────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ExampleAdmin123

# ── Stripe Payment ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_example_secret_key
STRIPE_CURRENCY=lkr

# ── Email / Nodemailer ───────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=example@gmail.com
EMAIL_PASS=example_app_password
EMAIL_FROM=QBus Tickets <example@gmail.com>
